# Database
DATABASE_URL=postgresql+asyncpg://taskplatform:taskplatform@localhost:5432/taskplatform
DATABASE_URL_SYNC=postgresql://taskplatform:taskplatform@localhost:5432/taskplatform

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
WEBHOOK_SECRET=dev-webhook-secret-change-me
WEBHOOK_HMAC_ENABLED=false

# Agent Simulator
SIMULATOR_HOST=0.0.0.0
SIMULATOR_PORT=8100
SIMULATOR_CALLBACK_DELAY_SECONDS=2
